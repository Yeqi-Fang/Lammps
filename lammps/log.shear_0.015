undump  msd_fine
reset_timestep  0   # 现在开始"真正 production 输出"，所有文件时间轴只出现一次
# 注意：fix ave/time (file_thermo, file_visc) 必须在 reset_timestep 之后定义，
#       否则 LAMMPS 报错：Cannot reset timestep with time-dependent fix ave/time defined

# --- Thermo output to file: instantaneous values every 100 steps ---
# Nevery=100, Nrepeat=1, Nfreq=100
# => sample at steps 100, 200, 300, ... (instantaneous, not averaged)
# Used by compute_viscosity.py to calculate steady-state eta.
fix  file_thermo  all  ave/time  100  1  100      v_samp_time  v_samp_gamma  v_samp_temp  v_samp_press  v_samp_pxy      file  thermo.shear_${SHEAR_RATE}.dat      title1  "# Inst thermo (SLLOD-consistent): gdot=${SHEAR_RATE} T=0.45 dt=${DT}"      title2  "# time  gamma  temp  press  pxy"
fix  file_thermo  all  ave/time  100  1  100      v_samp_time  v_samp_gamma  v_samp_temp  v_samp_press  v_samp_pxy      file  thermo.shear_0.015.dat      title1  "# Inst thermo (SLLOD-consistent): gdot=${SHEAR_RATE} T=0.45 dt=${DT}"      title2  "# time  gamma  temp  press  pxy"

# --- Block-averaged -P_xy for viscosity estimation ---
# Nevery=1, Nrepeat=100, Nfreq=100
# => average over consecutive 100-step blocks; output every 100 steps.
# eta_block = (-P_xy block average) / gamma_dot
fix  file_visc  all  ave/time  1  100  100      v_samp_time  v_samp_npxy      file  visc_blockave.shear_${SHEAR_RATE}.dat      title1  "# Block-averaged -<P_xy>: gamma_dot=${SHEAR_RATE}"      title2  "# time  -pxy_block100"
fix  file_visc  all  ave/time  1  100  100      v_samp_time  v_samp_npxy      file  visc_blockave.shear_0.015.dat      title1  "# Block-averaged -<P_xy>: gamma_dot=${SHEAR_RATE}"      title2  "# time  -pxy_block100"

# --- Atom trajectory dump (production) ---
# Output: id type x y z xu yu zu vx vy vz for all atoms
# xu/yu/zu = unwrapped coordinates (省去 Python 端手动 unwrap)
