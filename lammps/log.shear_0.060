# ===========================
# RESET STEP COUNTER
# ===========================
# Production data starts cleanly at step 0.
# fix deform and fix sllod_nvt continue uninterrupted.
reset_timestep  0

# ===========================
# PRODUCTION OUTPUT SETUP
# ===========================
# All output fixes are defined AFTER reset_timestep so step numbers in output
# files run from 0 to N_prod.

# --- Equal-style variables for fix ave/time ---
# These are evaluated at sample time by fix ave/time.
# Note: variable names chosen to avoid confusion with LAMMPS keywords.
variable  samp_step  equal  step
variable  samp_time  equal  time
variable  samp_temp  equal  c_Tdeform
variable  samp_press equal  c_Pdeform
variable  samp_pxy   equal  c_Pdeform[4]
variable  samp_npxy  equal  -c_Pdeform[4]    # -P_xy for viscosity: eta = (-P_xy)/gamma_dot
variable  samp_gamma equal  ${SHEAR_RATE}*time
variable  samp_gamma equal  0.060*time

# ===========================
# PRODUCTION RUN (Delta_gamma = 50)
# ===========================
print "=========================================="
==========================================
print "PRODUCTION RUN"
PRODUCTION RUN
print "  gamma_dot    = ${SHEAR_RATE}"
  gamma_dot    = 0.060
print "  N_prod steps = ${N_prod}  (strain = 50)"
  N_prod steps = 833333  (strain = 50)
print "  dump_every   = ${DUMP_EVERY}  steps"
  dump_every   = 333  steps
print "=========================================="
==========================================

# --- 前 2000 步密集 dump，用于 MSD 平台检测 ---
# Δt_fine = 10 × dt = 0.05 τ₀，覆盖 ballistic→plateau 转变
# 总时间 = 2000 × dt，足以看到平台
# 注意：fix ave/time 不在此处定义，避免触发 time-dependent fix 限制
dump  msd_fine  all  custom  10       dump.fine_${SHEAR_RATE}.lammpstrj       id  type  x  y  z  ix  iy  iz
dump  msd_fine  all  custom  10       dump.fine_0.060.lammpstrj       id  type  x  y  z  ix  iy  iz
dump_modify  msd_fine  sort  id  flush  yes

run   2000
